# Rede Docker compartilhada com o nginx central do servidor
EDGE_NETWORK=srvprojetos-edge

# Caminho publico da aplicacao no nginx
FRONTEND_BASE_PATH=/inovacao/fx-obras/

# URLs do frontend (build-time)
VITE_API_BASE_URL=/inovacao/fx-obras/api/v2
VITE_UPLOADS_BASE_URL=/inovacao/fx-obras
VITE_APP_NAME=Digital Rey
VITE_APP_MODULE_NAME=Prospecção de Obras
VITE_GOOGLE_MAPS_API_KEY=

# API
API_PORT=3333
DATABASE_URL=file:/app/data/prod.db
CORS_ORIGIN=https://projetos.reymaster.com.br
UPLOAD_DIR=uploads/construction-opportunities
MAX_PHOTOS_PER_OPPORTUNITY=15
MAX_PHOTO_SIZE_MB=10
APP_NAME=Obras Prospect
APP_CODE_PREFIX=OBR
