{
  "name": "obras-prospect",
  "version": "1.0.0",
  "description": "Obras Prospect MVP monorepo",
  "scripts": {
    "dev": "concurrently -n API,WEB -c cyan,magenta \"npm run dev:api\" \"npm run dev:web\"",
    "dev:all": "npm run dev",
    "dev:web": "npm run dev -w web",
    "dev:api": "npm run dev -w @obras-prospect/api",
    "mobile:url": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\show-mobile-url.ps1",
    "build": "npm run build -w @obras-prospect/api && npm run build -w web",
    "test": "npm run test -w @obras-prospect/api",
    "certs:generate": "node generate-certs.js",
    "certs:setup": "npm run certs:generate && npm run dev:web"
  },
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "concurrently": "^9.2.1",
    "node-forge": "^1.4.0"
  }
}
