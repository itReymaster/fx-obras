DB_PASSWORD=your_password_here
# Opcional: use Base64 para evitar problemas com caracteres especiais (ex: #)
# Exemplo (Linux): echo -n 'Service@#123' | base64
# Exemplo (PowerShell): [Convert]::ToBase64String([Text.Encoding]::UTF8.GetBytes('Service@#123'))
