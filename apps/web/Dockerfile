FROM node:22-alpine AS builder

WORKDIR /app

ARG VITE_BASE_PATH=/
ARG VITE_API_BASE_URL=/api/v2
ARG VITE_UPLOADS_BASE_URL=
ARG VITE_APP_NAME=Digital Rey
ARG VITE_APP_MODULE_NAME=Prospecção de Obras
ARG VITE_GOOGLE_MAPS_API_KEY=

ENV VITE_BASE_PATH=$VITE_BASE_PATH
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
ENV VITE_UPLOADS_BASE_URL=$VITE_UPLOADS_BASE_URL
ENV VITE_APP_NAME=$VITE_APP_NAME
ENV VITE_APP_MODULE_NAME=$VITE_APP_MODULE_NAME
ENV VITE_GOOGLE_MAPS_API_KEY=$VITE_GOOGLE_MAPS_API_KEY

COPY package.json ./
RUN npm install

COPY . .
RUN npm run build

FROM nginx:1.27-alpine AS runner

COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/dist /usr/share/nginx/html

EXPOSE 80
